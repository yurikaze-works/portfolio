                        "object-fit": "cover",
                        "border-radius": "0 !important",
                        "@media (max-width: 992px)": {
                          "height": "350px"
                        }
                      }
                    },
                    ".number-wrap": {
                      "position": "absolute",
                      "top": "0",
                      "left": "0",
                      "width": "100%",
                      "padding": "24px 24px 0 24px",
                      ".item-number": {
                        "display": "inline-block",
                        "padding": "4px 24px",
                        "background-color": "@number",
                        "margin-bottom": "0"
                      }
                    },
                    ".item-content": {
