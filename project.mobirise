                      },
                      ".item-text": {
                        "margin-bottom": "8px"
                      }
                    }
                  },
                  ".icon-wrapper": {
                    "padding": "0 24px 24px 24px",
                    "@media (max-width: 992px)": {
                      "padding": "0 16px 16px 16px"
                    },
                    ".mbr-iconfont": {
                      "display": "inline-block",
                      "font-size": "24px",
                      "color": "@icon"
                    }
                  }
                }
              }
            },
            ".mbr-section-title": {
              "color": "#ffffff",
              "text-align": "center"
            },
            ".mbr-text, .text-wrapper": {
              "color": "#9aa0a6",
              "text-align": "center"
            },
            ".item-title": {
