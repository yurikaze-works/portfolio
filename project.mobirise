              ".navbar-buttons": {
                "justify-content": "center",
                "width": "100%"
              }
            },
            "@media (max-width: 991px)": {
              ".navbar-brand": {
                "width": "auto !important",
                "max-width": "80% !important"
              },
              ".navbar-collapse": {
                "width": "100%"
